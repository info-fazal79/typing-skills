// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  passwordHash     String
  role             String            @default("STUDENT") // ADMIN, STUDENT
  courseName       String?
  batchName        String?
  rollNumber       String?
  status           String            @default("PENDING") // PENDING, APPROVED, REJECTED, SUSPENDED
  points           Int               @default(0)
  lastPenaltyCheck DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         PracticeSession[]
  submissions      TaskSubmission[]
  inactivityLogs   UserInactivityLog[]
}

model PracticeSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language     String   // ENGLISH, BANGLA
  mode         String   // standard, punctuation, numbers, vowels, consonants, modifiers, conjuncts, mixed
  wpm          Float
  accuracy     Float
  duration     Int      // seconds
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())
}

model Task {
  id               String            @id @default(uuid())
  title            String
  textContent      String
  language         String            // ENGLISH, BANGLA
  targetWpm        Float
  targetAccuracy   Float
  deadline         DateTime
  pointsAwardable  Int               @default(100)
  creatorId        String
  createdAt        DateTime          @default(now())
  assignments      TaskAssignment[]
  submissions      TaskSubmission[]
}

model TaskAssignment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  batchName String
  createdAt DateTime @default(now())

  @@unique([taskId, batchName])
}

model TaskSubmission {
  id           String   @id @default(uuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  studentId    String
  student      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  wpm          Float
  accuracy     Float
  pointsEarned Int      @default(0)
  completedAt  DateTime @default(now())
  isLate       Boolean  @default(false)

  @@unique([taskId, studentId])
}

model BatchTarget {
  id                 String   @id @default(uuid())
  batchName          String   @unique
  dailyTargetMinutes Int      @default(5)
  pointsDeduction    Int      @default(10) // Daily deduction points
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserInactivityLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           String   // YYYY-MM-DD
  pointsDeducted Int
  createdAt      DateTime @default(now())

  @@unique([userId, date])
}
